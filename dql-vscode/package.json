{
  "name": "dql-vscode",
  "displayName": "DQL Developer Tools",
  "description": "Developer-first, Arrow-native query virtualization layer for VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:sql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dql.pingDaemon",
        "title": "DQL: Ping Daemon"
      },
      {
        "command": "dql.executeQueryUI",
        "title": "DQL: Execute Query",
        "icon": "$(play)"
      },
      {
        "command": "dql.attachFile",
        "title": "DQL: Attach File as Table"
      },
      {
        "command": "dql.attachSQLite",
        "title": "DQL: Attach SQLite Table"
      },
      {
        "command": "dql.connectWizard",
        "title": "DQL: Connect Data Source",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dql.connectWizard",
          "when": "view == dqlDataSources",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "dql.executeQueryUI",
          "when": "resourceLangId == sql",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "dql.executeQueryUI",
          "when": "resourceLangId == sql",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "dql.executeQueryUI",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && editorLangId == sql"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dql-explorer",
          "title": "DQL Explorer",
          "icon": "media/dql-icon.svg"
        }
      ]
    },
    "views": {
      "dql-explorer": [
        {
          "id": "dqlDataSources",
          "name": "Data Sources",
          "type": "tree"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "typescript": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0"
  }
}
